{
  "alwaysThinkingEnabled": true,
  "enabledPlugins": {
    "checkmate@rcrsr": false,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-mem@thedotmack": false,
    "clippy-claude@clippy-claude": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": false,
    "example-skills@anthropic-agent-skills": false,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": false,
    "nx@nx-claude-plugins": false,
    "playwright@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "forceLoginMethod": "console",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "timeout": 10,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "timeout": 600,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "timeout": 10,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "timeout": 10,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "timeout": 10,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "timeout": 10,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "timeout": 10,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "curl -sS --connect-timeout 2 --max-time 5 -H 'Content-Type: application/json' --data-binary @- 'http://127.0.0.1:7823/hook' >/dev/null 2>&1 || true",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "timeout": 10,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "timeout": 10,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "timeout": 10,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "timeout": 10,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "timeout": 10,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "timeout": 10,
            "type": "http",
            "url": "http://127.0.0.1:7823/hook"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash(cargo:*)",
      "Bash(just:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(mise:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(rg:*)",
      "Bash(sd:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "Bash(sed:*)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "bash ~/.claude/statusline-command.sh",
    "type": "command"
  }
}